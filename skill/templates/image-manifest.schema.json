{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://storyvista.dev/schemas/image-manifest.schema.json",
  "title": "StoryVista Image Manifest v0.2",
  "type": "object",
  "required": ["schema_version", "provider_status", "binding_source", "allow_initials_avatar", "assets"],
  "properties": {
    "schema_version": { "const": "0.2.0" },
    "provider_status": { "type": "string" },
    "binding_source": { "const": "image-manifest.json" },
    "allow_initials_avatar": { "const": false },
    "assets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["asset_id", "bound_to", "file_path", "provider", "status", "generated_at", "prompt_ref", "alt_text", "license_note"],
        "properties": {
          "asset_id": { "type": "string", "minLength": 1 },
          "bound_to": { "type": "string", "minLength": 1 },
          "file_path": { "type": "string", "pattern": "^assets/" },
          "provider": { "type": "string", "minLength": 1 },
          "status": { "enum": ["planned", "prompt_ready", "generated", "user_provided", "placeholder", "missing", "failed"] },
          "generated_at": { "type": "string" },
          "prompt_ref": { "type": "string" },
          "alt_text": { "type": "string", "minLength": 1 },
          "license_note": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
