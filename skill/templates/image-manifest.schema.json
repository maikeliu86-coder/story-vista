{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://storyvista.dev/schemas/image-manifest.schema.json",
  "title": "StoryVista Image Manifest v0.4",
  "type": "object",
  "required": ["schema_version", "provider_status", "binding_source", "allow_initials_avatar", "assets"],
  "properties": {
    "schema_version": { "const": "0.4.0" },
    "provider_status": { "type": "string" },
    "binding_source": { "const": "image-manifest.json" },
    "allow_initials_avatar": { "const": false },
    "assets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["asset_id", "asset_type", "bound_to", "file_path", "placeholder_path", "expected_file_path", "expected_filename", "provider", "status", "generated_at", "prompt_ref", "prompt", "negative_prompt", "aspect_ratio", "style_mode", "alt_text", "license_note"],
        "properties": {
          "asset_id": { "type": "string", "minLength": 1 },
          "asset_type": { "type": "string", "minLength": 1 },
          "bound_to": { "type": "string", "minLength": 1 },
          "file_path": { "type": "string", "pattern": "^assets/" },
          "placeholder_path": { "type": "string", "pattern": "^assets/placeholders/" },
          "expected_file_path": { "type": "string", "pattern": "^assets/generated/" },
          "expected_filename": { "type": "string", "minLength": 1 },
          "provider": { "type": "string", "minLength": 1 },
          "status": { "enum": ["planned", "generated", "generated_external", "user_provided", "pending_external_generation", "prompt_only_ready", "placeholder", "failed", "skipped"] },
          "generated_at": { "type": "string" },
          "prompt_ref": { "type": "string" },
          "prompt": { "type": "string", "minLength": 1 },
          "negative_prompt": { "type": "string" },
          "aspect_ratio": { "type": "string" },
          "style_mode": { "enum": ["evidence-strict", "creative-balanced", "cinematic-free"] },
          "binding_method": { "type": "string" },
          "alt_text": { "type": "string", "minLength": 1 },
          "license_note": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
