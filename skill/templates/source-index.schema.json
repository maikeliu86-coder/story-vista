{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://storyvista.dev/schemas/source-index.schema.json",
  "title": "StoryVista Source Index",
  "type": "object",
  "required": ["schema_version", "sources"],
  "properties": {
    "schema_version": { "const": "0.3.0" },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["source_id", "path", "type", "title", "language", "character_count"],
        "properties": {
          "source_id": { "type": "string", "minLength": 1 },
          "path": { "type": "string", "minLength": 1 },
          "type": { "enum": ["text", "markdown"] },
          "title": { "type": "string", "minLength": 1 },
          "language": { "type": "string", "minLength": 2 },
          "created_at": { "type": "string" },
          "character_count": { "type": "integer", "minimum": 1 },
          "notes": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
