{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://storyvista.dev/schemas/story-atlas.schema.json",
  "title": "StoryVista Story Atlas v0.2",
  "type": "object",
  "required": ["schema_version", "metadata", "summary", "themes", "entities", "relations", "events", "timeline", "actor_mode", "visual_style", "evidence_index"],
  "properties": {
    "schema_version": { "const": "0.2.0" },
    "metadata": {
      "type": "object",
      "required": ["title", "mode", "status"],
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "mode": { "type": "string" },
        "status": { "type": "string" }
      },
      "additionalProperties": false
    },
    "summary": { "type": "string", "minLength": 1 },
    "themes": { "type": "array", "items": { "type": "string" } },
    "entities": {
      "type": "object",
      "required": ["characters", "locations", "organizations", "objects", "concepts"],
      "properties": {
        "characters": { "type": "array", "items": { "$ref": "#/$defs/entity" } },
        "locations": { "type": "array", "items": { "$ref": "#/$defs/entity" } },
        "organizations": { "type": "array", "items": { "$ref": "#/$defs/entity" } },
        "objects": { "type": "array", "items": { "$ref": "#/$defs/entity" } },
        "concepts": { "type": "array", "items": { "$ref": "#/$defs/entity" } }
      },
      "additionalProperties": false
    },
    "relations": { "type": "array", "items": { "$ref": "#/$defs/relation" } },
    "events": { "type": "array", "items": { "$ref": "#/$defs/event" } },
    "timeline": { "type": "array", "items": { "type": "object", "required": ["order", "event_id", "title"] } },
    "actor_mode": { "type": "object", "required": ["status", "characters"] },
    "visual_style": { "type": "object", "required": ["theme", "palette", "avoid"] },
    "evidence_index": { "type": "object", "additionalProperties": { "$ref": "#/$defs/evidence" } }
  },
  "$defs": {
    "evidence": {
      "type": "object",
      "required": ["source_id", "chunk_id", "quote", "summary", "confidence", "status"],
      "properties": {
        "source_id": { "type": "string" },
        "chunk_id": { "type": "string" },
        "quote": { "type": "string", "minLength": 1 },
        "summary": { "type": "string" },
        "confidence": { "enum": ["high", "medium", "low"] },
        "status": { "enum": ["explicit", "inferred", "ambiguous", "contradictory", "unresolved"] },
        "evidence_id": { "type": "string" }
      },
      "additionalProperties": false
    },
    "entity": {
      "type": "object",
      "required": ["entity_id", "name", "entity_type", "evidence"],
      "properties": {
        "entity_id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "entity_type": { "enum": ["character", "location", "organization", "object", "concept"] },
        "evidence": { "type": "array", "items": { "$ref": "#/$defs/evidence" } }
      },
      "additionalProperties": true
    },
    "relation": {
      "type": "object",
      "required": ["relation_id", "source_entity_id", "target_entity_id", "relation_type", "polarity", "strength", "status", "evidence"],
      "properties": {
        "relation_id": { "type": "string" },
        "source_entity_id": { "type": "string" },
        "target_entity_id": { "type": "string" },
        "relation_type": { "type": "string" },
        "polarity": { "type": "string" },
        "strength": { "type": "number", "minimum": 0, "maximum": 1 },
        "status": { "enum": ["explicit", "inferred", "ambiguous", "contradictory", "unresolved"] },
        "evidence": { "type": "array", "items": { "$ref": "#/$defs/evidence" } }
      },
      "additionalProperties": true
    },
    "event": {
      "type": "object",
      "required": ["event_id", "title", "summary", "participants", "timeline_order", "status", "evidence"],
      "properties": {
        "event_id": { "type": "string" },
        "title": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1 },
        "participants": { "type": "array", "items": { "type": "string" } },
        "location_id": { "type": ["string", "null"] },
        "timeline_order": { "type": "integer", "minimum": 1 },
        "status": { "enum": ["explicit", "inferred", "ambiguous", "contradictory", "unresolved"] },
        "evidence": { "type": "array", "items": { "$ref": "#/$defs/evidence" } }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
