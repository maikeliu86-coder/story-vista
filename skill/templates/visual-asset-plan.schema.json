{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://storyvista.dev/schemas/visual-asset-plan.schema.json",
  "title": "StoryVista Visual Asset Plan",
  "type": "object",
  "required": ["schema_version", "provider_status", "selected_provider", "fallback_provider", "prompt_only", "style_mode", "supported_style_modes", "assets"],
  "properties": {
    "schema_version": { "const": "0.4.0" },
    "provider_status": { "type": "string" },
    "selected_provider": { "type": "string" },
    "fallback_provider": { "type": "string" },
    "prompt_only": { "type": "boolean" },
    "style_mode": { "enum": ["evidence-strict", "creative-balanced", "cinematic-free"] },
    "supported_style_modes": { "type": "array" },
    "assets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["asset_id", "entity_name", "asset_type", "priority", "prompt", "localized_prompt", "negative_prompt", "aspect_ratio", "style_mode", "style_profile", "provider_preference", "status", "prompt_language", "source_language", "ui_language", "evidence_summary", "generation_notes", "expected_filename", "expected_file_path"],
        "properties": {
          "asset_id": { "type": "string", "minLength": 1 },
          "entity_id": { "type": ["string", "null"] },
          "event_id": { "type": ["string", "null"] },
          "location_id": { "type": ["string", "null"] },
          "entity_name": { "type": "string" },
          "asset_type": { "enum": ["character_portrait", "character_half_body", "character_first_scene", "location_keyart", "object_lore_keyart", "interpretive_map", "spoiler_safe_background"] },
          "priority": { "enum": ["high", "medium", "low"] },
          "prompt": { "type": "string", "minLength": 1 },
          "localized_prompt": { "type": "string" },
          "negative_prompt": { "type": "string" },
          "aspect_ratio": { "type": "string" },
          "style_mode": { "enum": ["evidence-strict", "creative-balanced", "cinematic-free"] },
          "style_profile": { "type": "string" },
          "provider_preference": { "type": "string" },
          "status": { "enum": ["prompt_only_ready", "pending_generation"] },
          "prompt_language": { "type": "string" },
          "source_language": { "type": "string" },
          "ui_language": { "type": "string" },
          "evidence_status": { "type": "string" },
          "evidence_summary": { "type": "string" },
          "generation_notes": { "type": "string" },
          "composition_note": { "type": "string" },
          "expected_filename": { "type": "string" },
          "expected_file_path": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
